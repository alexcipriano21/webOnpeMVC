@{
    ViewData["Title"] = "Inicio";
    ViewData["FooterClass"] = "footer-index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container space02 nosub">
    <div class="pull-left pd02 ancho-ie">
        <a href="@Url.Action("Index", "Home")">
            <div class="grow pic btn01"><img src="~/content/images/presidenciales.jpg" alt="Presidenciales"></div>
            <div class="tit02">
                <span class="glyphicon glyphicon-chevron-down" aria-hidden="true"></span>
                <p>PRESIDENCIALES</p>
            </div>
        </a>
    </div>

    <div class="pull-left pd02 oculto2 ancho-ie">
