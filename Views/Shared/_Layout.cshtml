<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=9" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ONPE</title>
    <link href="~/content/css/bootstrap.css" rel="stylesheet" />
    <link href="~/content/css/font-awesome.min.css" rel="stylesheet" />
    <link href="~/content/css/style.css" rel="stylesheet" />
</head>
<body>
    <header>
        <div class="container">
            <div class="pull-left logo-onpe">
                <div class="pull-left">
                    <a href="@Url.Action("Index","Home")">
                        <img src="~/content/images/onpe-trans.png" alt="ONPE">
                        </a>
                    </div>
                    <div class="pull-left">
                        <h1>PRESENTACIÓN DE RESULTADOS</h1>
                    </div>
                </div>
                <div class="pull-right logo">
                    <img src="~/content/images/eegg2016-trans.png" width="218" height="35" alt="EG 2016">
                    </div>
                </div>
            </header>

            @RenderBody()

            <footer class="@(ViewData["FooterClass"] ?? "footer-inside")">
                <div class="container">
                    <div class="row">
                        <div class="col-md-12 direc01">
                            <span>CONTÁCTENOS</span>
                            <p>Jr. Washington 1894, Cercado de Lima</p>
                            <p>Correo electrónico: <a href="#">informes@onpe.gob.pe</a></p>
                            <p>Central Telefónica: 417 - 0630 / Lunes a Viernes 08:30 - 16:30 hrs</p>
                        </div>
                    </div>
                </div>
            </footer>

            @RenderSection("Scripts", required: false)
        </body>
    </html>

