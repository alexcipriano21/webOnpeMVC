@model webOnpeMVC.Models.Ubigeo
@{
    ViewData["Title"] = "Actas por Ubigeo";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.MenuActivo = "Actas";
}

<div class="container">
    <img src="~/content/images/f-actas.jpg" width="1170" height="248" class="img-responsive mg30top" alt="Actas">

        @await Html.PartialAsync("_MenuNavegacion")
        <br /><br /><br /><br />

        <section class="contenedor">
            <div class="row">
                <div class="col-xs-12 col-md-3">
                    <div class="menu-interna">
                        <ul>
                            <li><a href="@Url.Action("Ubigeo","Actas")" class="act-izq">Actas por ubigeo</a></li>
                            <li><a href="@Url.Action("Numero","Actas")">Actas por número</a></li>
                        </ul>
                    </div>
                </div>

                <div class="col-xs-12 col-md-9" id="impreso">
                    <div class="contenido-interna">
                        <div class="titulos col-xs-12">
                            <div class="col-xs-11">
                                <h3>
                                    <span class="glyphicon glyphicon-circle-arrow-right" aria-hidden="true" style="font-size:19px"></span>
                                    SEGUNDA ELECCIÓN PRESIDENCIAL 2016: ACTAS POR UBIGEO
                                </h3>
                            </div>
                            <div class="col-xs-1 oculto-boton-print">
                                <button onclick="window.print()"><i class="fa fa-print ico-print"></i></button>
                            </div>
                        </div>

                        @await Html.PartialAsync("_ActasContabilizadas")

                        <div class="col-xs-12 td34up">
                            <form id="frmBuscar" class="horizontal-form" style="margin-bottom: 20px;">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label class="control-label">Ámbito:</label>
                                            <select id="selAmbito" class="form-control">
                                                <option value="Nacional">PERÚ</option>
                                                <option value="Extranjero">EXTRANJERO</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label id="lblNivel1" class="control-label">Departamento:</label>
                                            <select id="selDepartamento" class="form-control">
                                                <option value="">--SELECCIONE--</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label id="lblNivel2" class="control-label">Provincia:</label>
                                            <select id="selProvincia" class="form-control" disabled>
                                                <option value="">--SELECCIONE--</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label id="lblNivel3" class="control-label">Distrito:</label>
                                            <select id="selDistrito" class="form-control" disabled>
                                                <option value="">--SELECCIONE--</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        <div class="form-group">
                                            <label id="lblNivel4" class="control-label">Locales:</label>
                                            <select id="selLocal" class="form-control" disabled>
                                                <option value="">--SELECCIONE--</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </form>

                            <div id="divMesas" style="display:none;" class="col-xs-12 pbot30">
                                <p class="subtitle">LISTADO DE MESAS</p>
                                <div id="page-wrap">
                                    <table class="table17" cellspacing="0" id="tblMesas">
                                        <tbody id="tbodyMesas"></tbody>
                                    </table>
                                </div>
                            </div>

                            <div id="divDetalle" style="display:none;" class="ptop20">
                                <div class="contenido-resultados">
                                    <button id="btnRegresar" class="btn btn-primary" type="button" onclick="ocultarDetalle()">
                                        <span class="glyphicon glyphicon-chevron-left" aria-hidden="true"></span> REGRESAR
                                    </button>
                                    <p class="clearfix">&nbsp;</p>

                                    <div class="row">
                                        <div class="col-xs-3 col-md-4">
                                            <div class="mesap01">
                                                <img src="~/content/images/mp-sin.jpg" class="img-responsive">
                                                    Si requiere la imagen del acta, solicítela a través del procedimiento de acceso a la información pública.
                                                </div>
                                            </div>
                                            <div class="col-xs-9 col-md-8">
                                                <div class="row">
                                                    <div class="col-xs-12">
                                                        <p class="subtitle1">ACTA ELECTORAL</p>
                                                        <table class="table13" cellspacing="0">
                                                            <thead><tr><th>Mesa N°</th><th>N° Copia</th></tr></thead>
                                                            <tbody>
                                                                <tr>
                                                                    <td id="detMesaId"></td>
                                                                    <td id="detNCopia"></td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                    <div class="col-xs-12">
                                                        <p class="subtitle1">INFORMACIÓN UBIGEO</p>
                                                        <table class="table14" cellspacing="0">
                                                            <tbody>
                                                                <tr class="titulo_tabla">
                                                                    <td id="lblTDepartamento">Departamento</td>
                                                                    <td id="lblTProvincia">Provincia</td>
                                                                    <td id="lblTDistrito">Distrito</td>
                                                                    <td>Local de votación</td>
                                                                    <td>Dirección</td>
                                                                </tr>
                                                                <tr>
                                                                    <td id="detDepartamento"></td>
                                                                    <td id="detProvincia"></td>
                                                                    <td id="detDistrito"></td>
                                                                    <td id="detRazonSocial"></td>
                                                                    <td id="detDireccion"></td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                    <div class="col-xs-12">
                                                        <p class="subtitle1">INFORMACIÓN MESA</p>
                                                        <table class="table15" cellspacing="0">
                                                            <tbody>
                                                                <tr class="titulo_tabla">
                                                                    <td>Electores hábiles</td>
                                                                    <td>Total votantes</td>
                                                                    <td>Estado del acta</td>
                                                                </tr>
                                                                <tr>
                                                                    <td id="detElectores"></td>
                                                                    <td id="detVotantes"></td>
                                                                    <td id="detEstado"></td>
                                                                </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xs-12">
                                            <p class="subtitle1">INFORMACIÓN DEL ACTA ELECTORAL</p>
                                            <div id="page-wrap" class="cont-tabla1" style="margin-bottom: 50px;">
                                                <table class="table06">
                                                    <tbody>
                                                        <tr class="titulo_tabla">
                                                            <td colspan="2">Organización política</td>
                                                            <td>Total de Votos</td>
                                                        </tr>
                                                        <tr>
                                                            <td>PERUANOS POR EL KAMBIO</td>
                                                            <td><img width="40px" height="40px" src="~/content/images/simbolo_pkk.jpg"></td>
                                                            <td id="detP1"></td>
                                                        </tr>
                                                        <tr>
                                                            <td>FUERZA POPULAR</td>
                                                            <td><img width="40px" height="40px" src="~/content/images/simbolo_keyko.jpg"></td>
                                                            <td id="detP2"></td>
                                                        </tr>
                                                        <tr><td colspan="2">VOTOS EN BLANCO</td><td id="detBlancos"></td></tr>
                                                        <tr><td colspan="2">VOTOS NULOS</td><td id="detNulos"></td></tr>
                                                        <tr><td colspan="2">VOTOS IMPUGNADOS</td><td id="detImpugnados"></td></tr>
                                                        <tr><td colspan="2">TOTAL DE VOTOS EMITIDOS</td><td id="detTotal"></td></tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        @section Scripts {
            <script type="application/json" id="ubigeoData">
                {
                "nacional": @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Nacionales.Select(d => new { id = d.IdDepartamento, nombre = d.Detalle }))),
                "extranjero": @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Extranjeros.Select(d => new { id = d.IdDepartamento, nombre = d.Detalle })))
                }
            </script>
            <script src="~/js/ubigeo.js"></script>
        }
